{
  "$schema": "Marginalia design tokens — copy into Svelte project as src/lib/styles/tokens.json",
  "fonts": {
    "serif": "'Newsreader', Charter, 'Iowan Old Style', 'Source Serif 4', Georgia, serif",
    "sans":  "'Geist', ui-sans-serif, system-ui, -apple-system, sans-serif",
    "mono":  "'Geist Mono', ui-monospace, 'JetBrains Mono', Menlo, monospace"
  },
  "scale": {
    "type": {
      "h1":      { "size": 34,    "lineHeight": 1.18, "weight": 600, "letterSpacing": "-0.018em" },
      "h2":      { "size": 22,    "lineHeight": 1.3,  "weight": 600, "letterSpacing": "-0.012em" },
      "h3":      { "size": 17,    "lineHeight": 1.4,  "weight": 600 },
      "body":    { "size": 17.5,  "lineHeight": 1.62, "weight": 400, "letterSpacing": "-0.003em" },
      "code":    { "size": 13,    "lineHeight": 1.55, "weight": 400 },
      "uiLg":    { "size": 16,    "lineHeight": 1.4,  "weight": 500 },
      "ui":      { "size": 13,    "lineHeight": 1.5,  "weight": 400 },
      "uiSm":    { "size": 12,    "lineHeight": 1.5,  "weight": 400 },
      "caption": { "size": 11,    "lineHeight": 1.45, "weight": 400 },
      "monoSm":  { "size": 10.5,  "lineHeight": 1.4,  "weight": 400 }
    },
    "space": [0, 4, 8, 12, 16, 24, 32, 48, 64],
    "radius": { "none": 0, "xs": 3, "sm": 6, "md": 10, "lg": 14 },
    "control": {
      "buttonHeight": 28,
      "inputHeight": 26,
      "treeRowCompact": 22,
      "treeRowRegular": 26,
      "treeRowComfy": 30,
      "tabHeight": 32,
      "titleBarHeight": 36,
      "statusBarHeight": 24
    }
  },
  "themes": {
    "light_paper": {
      "bg":           "oklch(0.985 0.004 80)",
      "bg-2":         "oklch(0.975 0.004 80)",
      "bg-3":         "oklch(0.96 0.004 80)",
      "bg-titlebar":  "oklch(0.97 0.004 80)",
      "bg-hover":     "oklch(0.94 0.004 80)",
      "bg-active":    "oklch(0.92 0.005 35 / 0.6)",
      "fg":           "oklch(0.21 0.01 80)",
      "fg-2":         "oklch(0.42 0.008 80)",
      "fg-3":         "oklch(0.58 0.008 80)",
      "fg-4":         "oklch(0.72 0.006 80)",
      "line":         "oklch(0.21 0.01 80 / 0.08)",
      "line-strong":  "oklch(0.21 0.01 80 / 0.14)",
      "selection":    "oklch(0.62 0.13 35 / 0.18)",
      "highlight":    "oklch(0.92 0.07 90)",
      "shadow-sm":    "0 1px 0 oklch(0.21 0.01 80 / 0.04)",
      "shadow-md":    "0 8px 32px oklch(0.21 0.01 80 / 0.08), 0 1px 0 oklch(0.21 0.01 80 / 0.04)",
      "shadow-lg":    "0 20px 64px oklch(0.21 0.01 80 / 0.18), 0 2px 0 oklch(0.21 0.01 80 / 0.06)"
    },
    "dark_paper": {
      "bg":           "oklch(0.18 0.008 60)",
      "bg-2":         "oklch(0.165 0.008 60)",
      "bg-3":         "oklch(0.22 0.008 60)",
      "bg-titlebar":  "oklch(0.21 0.008 60)",
      "bg-hover":     "oklch(0.24 0.008 60)",
      "bg-active":    "oklch(0.28 0.02 35 / 0.6)",
      "fg":           "oklch(0.92 0.006 250)",
      "fg-2":         "oklch(0.68 0.008 250)",
      "fg-3":         "oklch(0.54 0.008 250)",
      "fg-4":         "oklch(0.42 0.008 250)",
      "line":         "oklch(0.92 0.006 250 / 0.08)",
      "line-strong":  "oklch(0.92 0.006 250 / 0.14)",
      "selection":    "oklch(0.62 0.13 35 / 0.28)",
      "highlight":    "oklch(0.32 0.07 90)",
      "shadow-sm":    "0 1px 0 oklch(0 0 0 / 0.3)",
      "shadow-md":    "0 8px 32px oklch(0 0 0 / 0.4)",
      "shadow-lg":    "0 20px 64px oklch(0 0 0 / 0.5), 0 2px 0 oklch(0 0 0 / 0.3)"
    }
  },
  "warmth": {
    "paper":   { "lightHue": 80,  "lightChroma": 0.004, "darkHue": 60,  "darkChroma": 0.008 },
    "neutral": { "lightHue": 250, "lightChroma": 0.001, "darkHue": 250, "darkChroma": 0.006 },
    "arctic":  { "lightHue": 240, "lightChroma": 0.006, "darkHue": 245, "darkChroma": 0.012 }
  },
  "accents": {
    "terracotta": "oklch(0.62 0.13 35)",
    "slate":      "oklch(0.55 0.07 250)",
    "sage":       "oklch(0.58 0.07 150)",
    "plum":       "oklch(0.55 0.11 320)",
    "ink":        "oklch(0.32 0.01 80)"
  },
  "syntax": {
    "light": {
      "kw":  "oklch(0.45 0.13 280)",
      "str": "oklch(0.5  0.09 145)",
      "num": "oklch(0.55 0.13 35)",
      "cmt": "oklch(0.62 0.008 80)",
      "fn":  "oklch(0.5  0.11 240)"
    },
    "dark": {
      "kw":  "oklch(0.74 0.13 290)",
      "str": "oklch(0.78 0.13 145)",
      "num": "oklch(0.78 0.13 35)",
      "cmt": "oklch(0.5  0.008 250)",
      "fn":  "oklch(0.78 0.11 230)"
    }
  },
  "motion": {
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)",
    "instant": 0,
    "fast": 120,
    "normal": 150,
    "slow": 200
  }
}
